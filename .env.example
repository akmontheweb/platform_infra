# =============================================================================
# platform-infra — Environment Variables (Template)
# =============================================================================
# Copy this file to .env.development (or .env.production) and run the
# rotation procedure described in SECRETS_RUNBOOK.md before running `make up`.
#
# All values marked `<CHANGE_ME>` must be replaced with strong random secrets.
# Generate with: openssl rand -hex 32
# =============================================================================

# ── Platform PostgreSQL (superuser — Terraform creates per-project DBs) ─────────
PLATFORM_PG_SUPERUSER=platform
PLATFORM_PG_SUPERPASSWORD=<CHANGE_ME>
PLATFORM_PG_PORT=5433          # use 5432 in prod

# ── Platform Keycloak database ──────────────────────────────────────────────────
PLATFORM_KC_DB_USER=keycloak
PLATFORM_KC_DB_PASSWORD=<CHANGE_ME>

# ── Platform Keycloak admin ─────────────────────────────────────────────────────
PLATFORM_KC_ADMIN_USER=admin
PLATFORM_KC_ADMIN_PASSWORD=<CHANGE_ME>
PLATFORM_HOSTNAME=<server IP or domain>
PLATFORM_KC_PUBLIC_URL=https://auth.yourdomain.com
PLATFORM_KC_HOSTNAME_STRICT=true   # set "false" only in dev on LAN IP
PLATFORM_KC_PORT=8081          # use 8080 in prod

# ── Platform MinIO root credentials ─────────────────────────────────────────────
PLATFORM_MINIO_ROOT_USER=platform
PLATFORM_MINIO_ROOT_PASSWORD=<CHANGE_ME>
PLATFORM_MINIO_PORT=9002       # use 9000 in prod
PLATFORM_MINIO_CONSOLE_PORT=9003

# ── Platform Redis (NEW — password required) ────────────────────────────────────
PLATFORM_REDIS_PORT=6380       # use 6379 in prod
PLATFORM_REDIS_PASSWORD=<CHANGE_ME>

# ── LiteLLM ─────────────────────────────────────────────────────────────────────
# Master key enables virtual key management (one per project, with budgets).
# Generate: python -c "import secrets; print('sk-' + secrets.token_hex(32))"
LITELLM_MASTER_KEY=<CHANGE_ME>
LITELLM_DATABASE_URL=postgresql://platform:<CHANGE_ME>@platform-postgres:5432/litellm
PLATFORM_LITELLM_PORT=4001     # use 4000 in prod

# LLM model assignments (shared via model aliases)
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=<CHANGE_ME>
OLLAMA_BASE_URL=http://host.docker.internal:11434
LLM_FAST_MODEL=openai/gpt-4o-mini
LLM_BALANCED_MODEL=openai/gpt-4o-mini
LLM_EMBEDDING_MODEL=openai/text-embedding-3-small
VOICE_TRANSCRIPT_MODEL=openai/whisper-1
LLM_VISION_MODEL=openai/gpt-4o-mini

# ── Observability ports ─────────────────────────────────────────────────────────
PLATFORM_OTEL_GRPC_PORT=4319   # use 4317 in prod
PLATFORM_OTEL_HTTP_PORT=4320
PLATFORM_OTEL_METRICS_PORT=8890
PLATFORM_JAEGER_UI_PORT=16687
PLATFORM_PROMETHEUS_PORT=9091
PLATFORM_GRAFANA_PORT=3002
PLATFORM_GRAFANA_ADMIN_PASSWORD=<CHANGE_ME>

# ── Caddy ───────────────────────────────────────────────────────────────────────
DOMAIN=yourdomain.com
CADDY_OBS_USER=admin
# Generate: docker run --rm caddy:2-alpine caddy hash-password --plaintext '<password>'
CADDY_OBS_PASSWORD_HASH=<CHANGE_ME>

# ── Platform MCP ────────────────────────────────────────────────────────────────
MCP_API_KEY=<CHANGE_ME>
PLATFORM_MCP_PORT=8010
LITELLM_API_KEY=

# Third-party MCP integrations — required for production deploy
TAVILY_API_KEY=<CHANGE_ME>
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASSWORD=<CHANGE_ME>
SMTP_FROM=support@yourdomain.com
TWILIO_ACCOUNT_SID=<CHANGE_ME>
TWILIO_AUTH_TOKEN=<CHANGE_ME>
TWILIO_PHONE_NUMBER=<CHANGE_ME>

# ── Alerting (Week 3) ───────────────────────────────────────────────────────────
# Email goes via the same Resend SMTP creds above. Set ALERTS_TO_EMAIL to the
# on-call distribution list. Leave ALERTS_SMS_WEBHOOK_URL blank to disable SMS;
# set it to your platform-mcp /alerts/sms endpoint or a Twilio sidecar URL to
# enable SMS for critical alerts only. See ALERTING_RUNBOOK.md.
ALERTS_TO_EMAIL=ops@yourdomain.com
ALERTS_SMS_WEBHOOK_URL=
PLATFORM_ALERTMANAGER_PORT=9094

# ── Terraform S3 backend (MinIO) ────────────────────────────────────────────────
# See SECRETS_RUNBOOK.md §5 for the bootstrap procedure.
TF_BACKEND_ACCESS_KEY=tf-state-rw
TF_BACKEND_SECRET_KEY=<CHANGE_ME>

# ── Cue bootstrap admin user ────────────────────────────────────────────────────
# Auto-provisioned by cue/scripts/grant-admin.sh --bootstrap as the final step
# of cue's FirstTimeSetup. Terraform writes these into cue/.env.platform via
# the project module's env.tpl, and consume-platform.sh overlays them onto
# cue/.env. Leave blank to skip bootstrap (typical for dev).
BOOTSTRAP_ADMIN_USERNAME=
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_FIRST_NAME=
BOOTSTRAP_ADMIN_LAST_NAME=
