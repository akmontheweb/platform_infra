# =============================================================================
# platform-infra — Caddy reverse proxy
#
# Base file imports per-project route snippets from ./routes/*.caddy
# Each project gets one file written by Terraform (scripts/provision-project.sh).
#
# Observability UIs protected with HTTP Basic Auth.
# Generate hash: docker run --rm caddy:2-alpine caddy hash-password --plaintext 'pw'
# =============================================================================

# Security headers applied to every site via `import security_headers`.
# HSTS only takes effect over HTTPS (Caddy auto-TLS).
(security_headers) {
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
        X-Frame-Options "DENY"
        -Server
    }
}

# Body-size ceiling at the edge. App-level limits (image upload, etc.) are
# stricter; this just bounds resource use before the body reaches the upstream.
(body_limit) {
    request_body {
        max_size 15MB
    }
}

# Observability — shared across all projects
grafana.{$DOMAIN} {
    import security_headers
    basic_auth {
        {$CADDY_OBS_USER} {$CADDY_OBS_PASSWORD_HASH}
    }
    reverse_proxy platform-grafana:3000
}

jaeger.{$DOMAIN} {
    import security_headers
    basic_auth {
        {$CADDY_OBS_USER} {$CADDY_OBS_PASSWORD_HASH}
    }
    reverse_proxy platform-jaeger:16686
}

auth.{$DOMAIN} {
    import security_headers
    # Keycloak's admin console embeds a same-origin session-check iframe
    # (login-status-iframe.html). The blanket DENY from security_headers
    # blocks it; SAMEORIGIN preserves clickjacking protection while letting
    # auth.* frame itself. Cross-origin framing is still denied.
    header X-Frame-Options "SAMEORIGIN"
    reverse_proxy platform-keycloak:8080
}

# Per-project routes (one .caddy file per project, written by Terraform)
import /etc/caddy/routes/*.caddy
